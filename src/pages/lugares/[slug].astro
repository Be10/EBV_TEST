---
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  getAllPlaces,
  type Place,
} from "../../lib/queries";

type Props = {
  place: Place;
};

export function getStaticPaths() {
  const places = getAllPlaces();

  return places
    .filter((place) => place.status !== "Borrador")
    .map((place) => ({
      params: { slug: place.slug },
      props: { place },
    }));
}

const { place } = Astro.props;
---

<BaseLayout
  title={place.name}
  description={place.summary ?? "Lugar de la Enciclopedia Bíblica Visual."}
>
  <main class="page">
    <div class="breadcrumb">
      <a href="/">Inicio</a> → Lugares → {place.name}
    </div>

    <section class="hero">
      <p class="eyebrow">{place.place_type ?? "Lugar bíblico"}</p>

      <h1>{place.name}</h1>

      {place.summary && (
        <p class="subtitle">
          {place.summary}
        </p>
      )}
    </section>

    <section class="section">
      <h2>Importancia bíblica</h2>

      <div class="content">
        <p>{place.summary ?? "Descripción pendiente."}</p>
      </div>
    </section>

    <section class="section">
      <h2>Estado del contenido</h2>

      <div class="content">
        <p>{place.status}</p>
      </div>
    </section>
  </main>
</BaseLayout>