---
import BaseLayout from "../../../layouts/BaseLayout.astro";

const lessons = [
  "La Biblia como una sola historia",
  "Dios crea todas las cosas",
  "La caída y el pecado",
  "La primera promesa de redención",
  "Noé, el juicio y la misericordia",
  "Babel y las naciones",
  "Abraham y la promesa",
  "El pacto con Abraham",
  "Isaac, Jacob y las doce tribus",
  "José y Egipto",
  "Moisés y el Éxodo",
  "La ley y el pacto en Sinaí",
  "El tabernáculo y la presencia de Dios",
  "La tierra prometida",
  "Los jueces y la necesidad de un rey",
  "David y el reino",
  "El templo y la adoración",
  "Profetas, exilio y esperanza",
  "Jesús, el Mesías prometido",
  "Cruz, resurrección, iglesia y nueva creación",
];
---

<BaseLayout
  title="Panorama Visual de la Biblia"
  description="Ruta guiada para entender la Biblia como una sola historia desde la creación hasta la nueva creación."
>
  <main class="page">
    <div class="breadcrumb">
      <a href="/">Inicio</a> → Rutas → Panorama Visual de la Biblia
    </div>

    <section class="hero">
      <p class="eyebrow">Ruta principal · 20 lecciones</p>

      <h1>Panorama Visual de la Biblia</h1>

      <p class="subtitle">
        Una ruta guiada para entender la Biblia como una sola historia centrada en Dios,
        la redención y el cumplimiento en Jesús.
      </p>

      <div class="actions">
        <a href="/lecciones/la-biblia-como-una-sola-historia/" class="button">
          Empezar lección 1
        </a>
      </div>
    </section>

    <section class="grid">
      <article class="card">
        <h2>Nivel</h2>
        <p>Básico a intermedio bajo.</p>
      </article>

      <article class="card">
        <h2>Duración</h2>
        <p>20 lecciones de 7 a 10 minutos.</p>
      </article>

      <article class="card">
        <h2>Objetivo</h2>
        <p>Comprender el hilo principal de la historia bíblica.</p>
      </article>
    </section>

    <section class="section">
      <h2>Lecciones de la ruta</h2>

      <ol class="list">
        {lessons.map((lesson, index) => (
          <li>
            {index === 0 ? (
              <a href="/lecciones/la-biblia-como-una-sola-historia/">{lesson}</a>
            ) : (
              <span>{lesson}</span>
            )}
          </li>
        ))}
      </ol>
    </section>
  </main>
</BaseLayout>